# Supabase Configuration (REQUIRED)
# Get these from your Supabase project: Settings > API
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Google Analytics (Optional - safe for frontend)
VITE_GOOGLE_ANALYTICS_ID=your-google-analytics-id-here

# Google AdSense (Optional - safe for frontend)
VITE_ADSENSE_ID=your-adsense-id-here

# Stripe Publishable Key (Optional - safe for frontend, this is the PUBLIC key)
VITE_STRIPE_PUBLISHABLE_KEY=your-stripe-publishable-key-here

# ============================================================
# Microsoft Outlook / Graph API (Phase D - D1 Email + D2 Calendar)
# Register app at https://portal.azure.com → Azure AD → App registrations
# Redirect URI: https://<your-domain>/auth/microsoft/callback
# Permissions: Mail.ReadWrite, Mail.Send, Calendars.ReadWrite, User.Read, offline_access
# ============================================================
VITE_MICROSOFT_CLIENT_ID=your-azure-app-client-id

# ============================================================
# QuickBooks Online (Phase D - D3 Payroll Sync)
# Register app at https://developer.intuit.com
# Redirect URI: https://<your-domain>/auth/quickbooks/callback
# ============================================================
VITE_QB_CLIENT_ID=your-quickbooks-client-id

# ============================================================
# WARNING: The following keys are SECRET and must NEVER be
# exposed in frontend code. Set them as Supabase Edge Function
# secrets or server-side environment variables ONLY.
# ============================================================
# MICROSOFT_CLIENT_ID=set-in-supabase-secrets        (same as VITE_ version)
# MICROSOFT_CLIENT_SECRET=set-in-supabase-secrets
# MICROSOFT_REDIRECT_URI=https://your-domain/auth/microsoft/callback
# QB_CLIENT_ID=set-in-supabase-secrets               (same as VITE_ version)
# QB_CLIENT_SECRET=set-in-supabase-secrets
# QB_REDIRECT_URI=https://your-domain/auth/quickbooks/callback
# QB_ENVIRONMENT=production                           (or 'sandbox' for testing)
# OPENAI_API_KEY=set-in-supabase-secrets
# ANTHROPIC_API_KEY=set-in-supabase-secrets
# TWILIO_ACCOUNT_SID=set-in-supabase-secrets
# TWILIO_AUTH_TOKEN=set-in-supabase-secrets
# ALLOWED_ORIGIN=https://your-production-domain.com
